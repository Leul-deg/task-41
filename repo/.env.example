APP_ENV=dev

POSTGRES_DB=meridian
POSTGRES_USER=meridian
POSTGRES_PASSWORD=meridian
DATABASE_URL=postgres://meridian:meridian@postgres:5432/meridian?sslmode=disable

JWT_SECRET=change-this-jwt-secret
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_HOURS=168
STEP_UP_TTL_MIN=5

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=LocalAdminPass123!

BOOTSTRAP_CLIENT_KEY=local-h5
BOOTSTRAP_CLIENT_SECRET=local-h5-secret-change-me
KIOSK_SUBMIT_SECRET=local-kiosk-submit-secret-change-me
H5_KIOSK_SUBMIT_SECRET=local-kiosk-submit-secret-change-me

IDEMPOTENCY_TTL_HOURS=48
ENABLE_FUZZY_DEDUP=true
PII_KEY_NAME=PII_DEFAULT
PII_KEY_VALUE=change-this-local-pii-key

FRONTEND_PORT=8081
BACKEND_PORT=8080
FRONTEND_COOKIE_SECURE=false
